{
    "version": 2,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "apps/crm/dist"
            }
        },
        {
            "src": "api/index.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "packages/api/src/db/migrations/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/v1/(.*)",
            "dest": "api/index.js"
        },
        {
            "src": "/uploads/(.*)",
            "dest": "api/index.js"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "index.html"
        }
    ]
}